// ==UserScript==
// @name         Sudoku.com Notes Toggle 
// @namespace    http://tampermonkey.net/
// @version      1.3
// @description  Uses mousedown event to toggle Notes on Sudoku.com
// @author       rriioot
// @match        *://*.sudoku.com/*
// @match        *://sudoku.com/*
// @grant        none
// ==/UserScript==

(function() {
    'use strict';

    const PENCIL_SELECTOR = ".game-controls-pencil";

    document.addEventListener('keydown', function(event) {
        // Prevent the toggle from firing 50 times a second if you hold the key down
        if (event.repeat) return;

        if (event.key === 'Shift' || event.key === 'Alt' || event.key === 'Control') {
            const pencilBtn = document.querySelector(PENCIL_SELECTOR);
            
            if (pencilBtn) {
                if (event.key === 'Alt') {
                    event.preventDefault(); // Stop the browser menu from opening
                }
                
                // Sudoku.com specifically requires a 'mousedown' event
                const mouseDownEvent = new MouseEvent('mousedown', {
                    bubbles: true,
                    cancelable: true,
                    view: window
                });
                
                pencilBtn.dispatchEvent(mouseDownEvent);
            }
        }
    });
})();
